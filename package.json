{
  "name": "gauge",
  "version": "0.1.6",
  "private": true,
  "description": "Unit converter",
  "main": "index.js",
  "scripts": {
    "gen-units": "node _data_/index.js",
    "build": "flatpak run org.flatpak.Builder --force-clean --sandbox --user --install --install-deps-from=flathub --ccache --mirror-screenshots-url=https://dl.flathub.org/media/ --repo=repo builddir io.github.josephmawa.Gauge.json",
    "lint-manifest": "flatpak run --command=flatpak-builder-lint org.flatpak.Builder manifest io.github.josephmawa.Gauge.json",
    "lint-appstream": "flatpak run --command=flatpak-builder-lint org.flatpak.Builder appstream data/io.github.josephmawa.Gauge.metainfo.xml.in",
    "lint-builddir": "flatpak run --command=flatpak-builder-lint org.flatpak.Builder builddir builddir",
    "lint-repo": "flatpak run --command=flatpak-builder-lint org.flatpak.Builder repo repo",
    "lint": "npm run build && npm run lint-manifest && npm run lint-appstream && npm run lint-builddir && npm run lint-repo",
    "init-build-dir": "flatpak run --command=meson --filesystem=host org.gnome.Sdk/x86_64/50 setup --wipe build-dir .",
    "gen-pot": "npm run init-build-dir && flatpak run --command=meson --filesystem=host org.gnome.Sdk/x86_64/50 compile -C build-dir Gauge-pot",
    "rm-build-artifacts": "rm -rf .flatpak-builder builddir repo build-dir"
  },
  "keywords": [
    "Unit",
    "Converter"
  ],
  "author": "Joseph Mawa",
  "license": "GPL-3.0-or-later",
  "type": "commonjs"
}
